---
// Mérés + konverziókövetés. Minden rész csak akkor tölt be, ha a hozzá tartozó
// azonosító meg van adva (Netlify env-változó). Lásd: src/config/analytics.ts
import { ANALYTICS } from '../config/analytics';
const { ga4Id, googleAdsId, googleAdsConversionLabel, metaPixelId, gscVerification } = ANALYTICS;
const gtagId = ga4Id || googleAdsId;
const adsSendTo = googleAdsId && googleAdsConversionLabel
  ? `${googleAdsId}/${googleAdsConversionLabel}`
  : '';
---

{gscVerification && <meta name="google-site-verification" content={gscVerification} />}

{gtagId && (
  <Fragment>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gtagId}`}></script>
    <script is:inline define:vars={{ ga4Id, googleAdsId, adsSendTo, metaPixelId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;

      // GDPR: alapból minden tárolás TILTVA (Google Consent Mode v2).
      // A gtag ilyenkor sütimentes jelzéseket küld; teljes mérés csak
      // "Elfogadom" után indul.
      gtag('consent', 'default', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });

      var GRANT = { ad_storage:'granted', analytics_storage:'granted', ad_user_data:'granted', ad_personalization:'granted' };
      var stored = null;
      try { stored = localStorage.getItem('fms-cookie-consent'); } catch (e) {}
      if (stored === 'granted') gtag('consent', 'update', GRANT);

      gtag('js', new Date());
      if (ga4Id) gtag('config', ga4Id);
      if (googleAdsId) gtag('config', googleAdsId);
      if (adsSendTo) document.documentElement.setAttribute('data-ads-send-to', adsSendTo);

      // Meta Pixel csak hozzájárulás után indul (nincs beépített consent mode-ja).
      window.fmsInitPixel = function () {
        if (!metaPixelId || window.__fmsPixelReady) return;
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
          n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
          document,'script','https://connect.facebook.net/en_US/fbevents.js');
        window.fbq('init', metaPixelId);
        window.fbq('track', 'PageView');
        window.__fmsPixelReady = true;
      };

      // A süti-sáv gombjai ezeket hívják.
      window.fmsGrantConsent = function () { gtag('consent', 'update', GRANT); window.fmsInitPixel(); };
      window.fmsDenyConsent = function () { /* marad denied */ };

      if (stored === 'granted') window.fmsInitPixel();
    </script>
  </Fragment>
)}

<!-- Egységes eseménykövetés: biztonságos wrapper + tel:/Viber kattintás -->
<script is:inline>
  (function () {
    function track(name, params) {
      try {
        if (window.gtag) window.gtag('event', name, params || {});
        if (window.fbq) window.fbq('trackCustom', name, params || {});
      } catch (e) {}
    }
    window.fmsTrack = track;

    // Konverzió: sikeres foglalás / ajánlatkérés esetén hívjuk.
    // name pl. 'foglalas' vagy 'ajanlatkeres' (GA4 + Meta eseménynévhez).
    window.fmsConversion = function (name) {
      try {
        var sendTo = document.documentElement.getAttribute('data-ads-send-to') || '';
        if (window.gtag && sendTo) {
          window.gtag('event', 'conversion', { send_to: sendTo, value: 1.0, currency: 'HUF' });
        }
        if (window.fbq) window.fbq('track', 'Lead');
        track(name || 'lead');
      } catch (e) {}
    };

    document.addEventListener('click', function (e) {
      var a = e.target && e.target.closest ? e.target.closest('a') : null;
      if (!a) return;
      var href = a.getAttribute('href') || '';
      if (href.indexOf('tel:') === 0) track('hivas_kattintas');
      else if (href.indexOf('viber') !== -1) track('viber_kattintas');
    }, true);
  })();
</script>
