---
import Logo from './Logo.astro';
import { SITE } from '../config/site';
import { weeklySchedule } from '../config/openingHours';
---

<footer style="background:#0F172A;color:#CBD5E1;">
  <div class="container" style="padding-top:3rem;padding-bottom:2rem;">

    <div style="display:grid;grid-template-columns:1fr;gap:2.5rem;" class="md:grid-cols-3-footer">
      <!-- Brand col -->
      <div>
        <Logo class="footer-logo" size="md" />
        <p style="margin-top:1rem;font-size:0.9rem;line-height:1.7;color:#94A3B8;max-width:280px;">
          Ninebot, Xiaomi és replika elektromos roller szerviz Budapesten. Gyors, megbízható, személyes kiszolgálás.
        </p>
        <div style="display:flex;gap:0.75rem;margin-top:1.25rem;flex-wrap:wrap;">
          <a href={`tel:${SITE.phone}`}
            style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;background:rgba(255,107,0,0.15);color:#FF6B00;border-radius:0.625rem;font-size:0.875rem;font-weight:600;text-decoration:none;border:1px solid rgba(255,107,0,0.3);transition:background 150ms;"
            onmouseover="this.style.background='rgba(255,107,0,0.25)'"
            onmouseout="this.style.background='rgba(255,107,0,0.15)'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.13 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            {SITE.phoneDisplay}
          </a>
          <a href={SITE.socialViber}
            target="_blank" rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;background:rgba(115,96,242,0.15);color:#9d8cf5;border-radius:0.625rem;font-size:0.875rem;font-weight:600;text-decoration:none;border:1px solid rgba(115,96,242,0.3);transition:background 150ms;"
            onmouseover="this.style.background='rgba(115,96,242,0.25)'"
            onmouseout="this.style.background='rgba(115,96,242,0.15)'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3C6.9 3 3 6.6 3 11c0 2 .8 3.9 2.2 5.3L4.5 21l4.9-1.3c.8.2 1.7.3 2.6.3 5.1 0 9-3.6 9-8s-3.9-8-9-8z" fill="currentColor"/><circle cx="9" cy="11" r="1" fill="#0F172A"/><circle cx="12" cy="11" r="1" fill="#0F172A"/><circle cx="15" cy="11" r="1" fill="#0F172A"/></svg>
            Viber
          </a>
        </div>
      </div>

      <!-- Navigation col -->
      <div>
        <h3 style="font-size:0.8rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#64748B;margin-bottom:1rem;">Oldalak</h3>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.5rem;">
          {[
            { href: '/', label: 'Főoldal' },
            { href: '/szolgaltatasok', label: 'Szolgáltatások és árak' },
            { href: '/tuning', label: 'Tuning és fejlesztés' },
            { href: '/idopontfoglalas', label: 'Időpontfoglalás' },
            { href: '/kapcsolat', label: 'Kapcsolat' },
          ].map(item => (
            <li>
              <a href={item.href} class="footer-nav-link"
                style="color:#94A3B8;text-decoration:none;font-size:0.9rem;transition:color 150ms;"
                onmouseover="this.style.color='#FF6B00'"
                onmouseout="this.style.color='#94A3B8'">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Hours col -->
      <div>
        <h3 style="font-size:0.8rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#64748B;margin-bottom:1rem;">Nyitvatartás</h3>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.375rem;">
          {weeklySchedule.map(day => (
            <li style="display:flex;justify-content:space-between;font-size:0.875rem;">
              <span style={`color:${day.open ? '#CBD5E1' : '#475569'};`}>{day.name}</span>
              <span style={`font-weight:${day.open ? '500' : '400'};color:${day.open ? '#94A3B8' : '#475569'};font-style:${day.open ? 'normal' : 'italic'};`}>
                {day.open ? day.hours : 'Zárva'}
              </span>
            </li>
          ))}
        </ul>
        <p style="margin-top:0.875rem;font-size:0.8rem;color:#475569;line-height:1.5;">
          Rugalmas beosztás – ha nem fér be a fenti időkeretbe, írj, egyeztetünk.
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="margin-top:2.5rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.07);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:0.75rem;">
      <p style="font-size:0.8rem;color:#475569;">
        © {new Date().getFullYear()} {SITE.name}. Minden jog fenntartva.
      </p>
      <div style="display:flex;gap:1.25rem;">
        {[
          { href: '/adatkezelesi-tajekoztato', label: 'Adatkezelési tájékoztató' },
          { href: '/impresszum', label: 'Impresszum' },
        ].map(item => (
          <a href={item.href}
            style="font-size:0.8rem;color:#475569;text-decoration:none;transition:color 150ms;"
            onmouseover="this.style.color='#94A3B8'"
            onmouseout="this.style.color='#475569'">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  /* Responsive grid for footer columns */
  @media (min-width: 768px) {
    .md\:grid-cols-3-footer {
      grid-template-columns: 1.4fr 1fr 1.2fr !important;
    }
  }
  /* Override logo color in dark footer */
  .footer-logo span { filter: brightness(1.3); }
  /* Mobilon nagyobb tapadó felület a footer linkeknek (könnyebb tappelés) */
  @media (max-width: 640px) {
    .footer-nav-link { display: inline-block; padding: 0.4rem 0; }
  }
</style>
