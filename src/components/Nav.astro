---
import Logo from './Logo.astro';
import { SITE } from '../config/site';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Főoldal' },
  { href: '/szolgaltatasok', label: 'Szolgáltatások' },
  { href: '/tuning', label: 'Tuning' },
  { href: '/kapcsolat', label: 'Kapcsolat' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,0.97);backdrop-filter:blur(8px);border-bottom:1px solid #E2E8F0;box-shadow:0 1px 4px rgba(0,0,0,0.04);">
  <nav class="container" style="display:flex;align-items:center;justify-content:space-between;height:4rem;" aria-label="Főnavigáció">
    <Logo size="md" />

    <!-- Desktop nav -->
    <ul style="align-items:center;gap:0.25rem;list-style:none;margin:0;padding:0;" class="nav-desktop">
      {navItems.map(item => (
        <li>
          <a href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            style={`
              display:block;
              padding:0.4rem 0.875rem;
              border-radius:0.5rem;
              font-size:0.9375rem;
              font-weight:${isActive(item.href) ? '700' : '500'};
              color:${isActive(item.href) ? '#1848A0' : '#374151'};
              background:${isActive(item.href) ? '#EFF6FF' : 'transparent'};
              text-decoration:none;
              transition:background 150ms,color 150ms;
            `}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop: telefonszám + CTA -->
    <a href={`tel:${SITE.phone}`} class="nav-phone" aria-label="Hívás">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.13 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
      {SITE.phoneDisplay}
    </a>
    <a href="/idopontfoglalas" class="btn-primary nav-cta" style="padding:0.5rem 1.25rem;font-size:0.9rem;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Időpontfoglalás
    </a>

    <!-- Mobile hamburger -->
    <button id="nav-toggle" aria-label="Menü megnyitása" aria-expanded="false" aria-controls="mobile-menu"
      style="align-items:center;justify-content:center;width:2.5rem;height:2.5rem;border-radius:0.5rem;border:none;background:transparent;cursor:pointer;color:#374151;"
      class="nav-burger">
      <svg id="hamburger-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="close-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" style="display:none;">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" hidden
    style="border-top:1px solid #E2E8F0;background:white;">
    <ul style="list-style:none;margin:0;padding:0.75rem 1.25rem 1rem;">
      {navItems.map(item => (
        <li>
          <a href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            style={`
              display:block;
              padding:0.75rem 0.875rem;
              border-radius:0.625rem;
              font-size:1rem;
              font-weight:${isActive(item.href) ? '700' : '500'};
              color:${isActive(item.href) ? '#1848A0' : '#374151'};
              background:${isActive(item.href) ? '#EFF6FF' : 'transparent'};
              text-decoration:none;
              margin-bottom:0.125rem;
            `}>
            {item.label}
          </a>
        </li>
      ))}
      <li style="padding-top:0.5rem;">
        <a href="/idopontfoglalas" class="btn-primary" style="width:100%;justify-content:center;">
          Időpontfoglalás
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.hidden;
    if (menu) menu.hidden = isOpen;
    toggle.setAttribute('aria-expanded', String(!isOpen));
    if (hamburger) hamburger.style.display = isOpen ? '' : 'none';
    if (closeIcon) closeIcon.style.display = isOpen ? 'none' : '';
  });
</script>

<style>
  /* Mobil: hamburger látszik, desktop menü/CTA rejtve */
  .nav-desktop { display: none; }
  .nav-cta { display: none !important; }
  .nav-phone { display: none; }
  .nav-burger { display: flex; }

  /* Asztali (>=768px): fordítva */
  @media (min-width: 768px) {
    .nav-desktop { display: flex; }
    .nav-cta { display: inline-flex !important; }
    .nav-burger { display: none; }
    #mobile-menu { display: none !important; }
  }
  /* Telefonszám csak szélesebb desktopon, hogy ne zsúfolja a navot */
  @media (min-width: 1000px) {
    .nav-phone {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-weight: 800; font-size: 0.95rem; color: #1848A0;
      text-decoration: none; white-space: nowrap; margin-left: auto;
      margin-right: 0.875rem;
    }
    .nav-phone:hover { color: #FF6B00; }
  }
</style>
