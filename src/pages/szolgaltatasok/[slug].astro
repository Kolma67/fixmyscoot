---
import Layout from '../../layouts/Layout.astro';
import { SITE } from '../../config/site';
import { getCollection } from 'astro:content';
import { getServiceMeta, ICONS } from '../../config/serviceCatalog';
import { getBrandLogo, getBrandLogoFallback } from '../../config/brands';

export async function getStaticPaths() {
  const scooters = await getCollection('scooters');
  return scooters.map(s => ({ params: { slug: s.id }, props: { scooter: s } }));
}

const { scooter } = Astro.props;
const fmt = (n: number) => n.toLocaleString('hu-HU');

const services = scooter.data.services.map(svc => {
  const meta = getServiceMeta(svc.name);
  return {
    name: svc.name,
    price: svc.price,
    note: svc.note ?? '',
    description: svc.description ?? meta.description,
    duration: svc.duration ?? meta.duration,
    icon: meta.icon,
    image: svc.image ?? scooter.data.image ?? null,
  };
});

const model = scooter.data.model;
const brand = scooter.data.brand;
const prices = services.map(s => s.price);
const minPrice = Math.min(...prices);
const maxPrice = Math.max(...prices);

const pageUrl = `${SITE.url}/szolgaltatasok/${scooter.id}`;
const description = `${model} elektromos roller szerviz és javítás Budapesten (Óbuda, III. kerület). `
  + `${services.length} szolgáltatás átlátható árakkal: ${services.slice(0, 4).map(s => s.name).join(', ')} és több. `
  + `Árak ${fmt(minPrice)} Ft-tól. Gyors átfutás, valódi diagnózis.`;

// Strukturált adatok
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Főoldal', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Szolgáltatások', item: `${SITE.url}/szolgaltatasok` },
    { '@type': 'ListItem', position: 3, name: model, item: pageUrl },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: `${model} elektromos roller szerviz`,
  provider: {
    '@type': 'LocalBusiness',
    name: SITE.name,
    telephone: SITE.phone,
    address: {
      '@type': 'PostalAddress',
      streetAddress: SITE.address.street,
      addressLocality: SITE.address.city,
      postalCode: SITE.address.zip,
      addressCountry: SITE.address.country,
    },
    url: SITE.url,
  },
  areaServed: { '@type': 'City', name: 'Budapest' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `${model} szolgáltatások és árak`,
    itemListElement: services.map(s => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.name },
      price: s.price,
      priceCurrency: 'HUF',
    })),
  },
};
---

<Layout
  title={`${model} szerviz és javítás Budapest`}
  description={description}
  canonicalPath={`/szolgaltatasok/${scooter.id}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="head" />

  <!-- Hero -->
  <section class="hero-gradient" style="color:white;padding:3rem 0 2.5rem;">
    <div class="container" style="max-width:820px;margin:0 auto;">
      <nav aria-label="Morzsamenü" style="font-size:0.85rem;opacity:0.85;margin-bottom:1rem;">
        <a href="/" style="color:white;text-decoration:none;">Főoldal</a>
        <span style="opacity:0.6;"> / </span>
        <a href="/szolgaltatasok" style="color:white;text-decoration:none;">Szolgáltatások</a>
        <span style="opacity:0.6;"> / </span>
        <span style="opacity:0.9;">{model}</span>
      </nav>
      <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:0.875rem;">
        <img src={getBrandLogo(brand)} data-fallback={getBrandLogoFallback(brand)} alt={`${brand} logó`} width="56" height="56" style="width:56px;height:56px;border-radius:0.7rem;background:white;padding:4px;flex-shrink:0;object-fit:contain;" onerror="if(this.src!==this.dataset.fallback){this.src=this.dataset.fallback;}" />
        <span class="badge" style="background:rgba(255,255,255,0.15);color:white;">{brand}</span>
      </div>
      <h1 style="font-size:clamp(1.6rem,4.5vw,2.5rem);font-weight:900;line-height:1.15;margin-bottom:0.875rem;letter-spacing:-0.02em;">
        {model} szerviz és javítás Budapesten
      </h1>
      <p style="font-size:1.02rem;line-height:1.7;opacity:0.92;max-width:640px;">
        {services.length} elérhető szolgáltatás a(z) {model} modellhez – átlátható árakkal
        ({fmt(minPrice)}–{fmt(maxPrice)} Ft), valódi diagnózissal. Óbuda, III. kerület.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <!-- Kereső -->
      <div style="position:relative;max-width:420px;margin:0 auto 1.75rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="position:absolute;left:0.85rem;top:50%;transform:translateY(-50%);pointer-events:none;" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search" id="svc-search" class="detail-search" placeholder="Keresés a szolgáltatások között…" aria-label={`Keresés a(z) ${model} szolgáltatásai között`} />
      </div>

      <div class="svc-grid sm:grid-2 lg:grid-3" style="display:grid;gap:1.25rem;grid-template-columns:1fr;">
        {services.map(svc => (
          <article class="card service-card" data-search={`${svc.name} ${svc.description}`.toLowerCase()} style="display:flex;flex-direction:column;overflow:hidden;">
            <div class="service-media">
              {svc.image ? (
                <img src={svc.image} alt={`${model} – ${svc.name}`} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
              ) : null}
              <div class="service-media-fallback" style={svc.image ? 'display:none;' : 'display:flex;'}>
                <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={ICONS[svc.icon]} />
              </div>
            </div>
            <div style="padding:1.125rem 1.25rem;display:flex;flex-direction:column;flex:1;">
              <h2 style="font-size:1.05rem;font-weight:800;color:#1E293B;margin-bottom:0.5rem;line-height:1.25;">{svc.name}</h2>
              <p style="font-size:0.875rem;color:#64748B;line-height:1.6;margin-bottom:1rem;flex:1;">{svc.description}</p>
              <div style="display:flex;align-items:baseline;justify-content:space-between;gap:0.5rem;margin-bottom:0.875rem;">
                <div>
                  <span style="font-size:0.72rem;color:#94A3B8;display:block;">Ár</span>
                  <span style="font-size:1.25rem;font-weight:900;color:#1848A0;">{fmt(svc.price)} Ft{svc.note}</span>
                </div>
                <div style="text-align:right;">
                  <span style="font-size:0.72rem;color:#94A3B8;display:block;">Időtartam</span>
                  <span style="font-size:0.85rem;font-weight:600;color:#475569;">{svc.duration}</span>
                </div>
              </div>
              <a href={`/idopontfoglalas?roller=${scooter.id}&szolgaltatas=${encodeURIComponent(svc.name)}`} class="btn-primary" style="width:100%;justify-content:center;font-size:0.9rem;">
                Időpontot kérek
              </a>
            </div>
          </article>
        ))}
      </div>

      <p id="svc-empty" hidden style="text-align:center;color:#94A3B8;padding:2.5rem 1rem;font-size:0.95rem;">
        Nincs a keresésnek megfelelő szolgáltatás.
      </p>

      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/szolgaltatasok" class="btn-secondary">← Összes roller típus</a>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 640px) { .sm\:grid-2 { grid-template-columns: repeat(2,1fr) !important; } }
    @media (min-width: 1024px) { .lg\:grid-3 { grid-template-columns: repeat(3,1fr) !important; } }

    .service-media {
      position: relative; aspect-ratio: 1 / 1;
      background: radial-gradient(circle at 50% 42%, #E1E2E4 0%, #C6C9CD 68%, #B4B7BC 100%);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; border-bottom: 1px solid #E2E8F0;
    }
    .service-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .service-media-fallback { position: absolute; inset: 0; align-items: center; justify-content: center; color: #1848A0; }
    .service-card { border-radius: 1rem; }
    .detail-search {
      width: 100%; padding: 0.7rem 0.875rem 0.7rem 2.5rem;
      border: 1.5px solid #E2E8F0; border-radius: 0.75rem; font-size: 0.95rem;
      outline: none; background: white; transition: border-color 150ms;
      box-sizing: border-box; font-family: inherit;
    }
    .detail-search:focus { border-color: #1848A0; }
  </style>

  <script>
    const input = document.getElementById('svc-search') as HTMLInputElement | null;
    const empty = document.getElementById('svc-empty');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.service-card'));
    input?.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let visible = 0;
      cards.forEach(c => {
        const match = !q || (c.dataset.search || '').includes(q);
        c.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (empty) empty.hidden = visible > 0;
    });
  </script>
</Layout>
