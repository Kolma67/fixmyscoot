---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { getCollection } from 'astro:content';
import { getBrandLogo, getBrandLogoFallback } from '../config/brands';
import home from '../data/home.json';

const scooters = (await getCollection('scooters'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const fmtHuf = (n: number) => n.toLocaleString('hu-HU');

// LocalBusiness JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "description": SITE.description,
  "url": SITE.url,
  "telephone": SITE.phone,
  "email": SITE.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": SITE.address.street,
    "addressLocality": SITE.address.city,
    "postalCode": SITE.address.zip,
    "addressCountry": SITE.address.country,
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": SITE.geo.latitude,
    "longitude": SITE.geo.longitude,
  },
  "priceRange": SITE.priceRange,
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "14:00" },
  ],
  "knowsAbout": ["Ninebot elektromos roller javítás", "Kukirin roller szerviz", "Xiaomi-kompatibilis elektromos roller", "E-roller karbantartás"],
};

// BreadcrumbList
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Főoldal", "item": SITE.url }],
};
---

<Layout
  title={SITE.name}
  description={SITE.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />

  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section style="background:linear-gradient(135deg,#0F2F6E 0%,#1848A0 50%,#1E5BBF 100%);color:white;padding:5rem 0 4rem;">
    <div class="container" style="display:grid;gap:2.5rem;align-items:center;" class="md:grid-hero">
      <div>
        <p style="display:inline-block;background:rgba(255,107,0,0.2);color:#FFA060;font-size:0.8rem;font-weight:700;padding:0.35rem 0.875rem;border-radius:9999px;letter-spacing:0.06em;text-transform:uppercase;border:1px solid rgba(255,107,0,0.35);margin-bottom:1.25rem;">
          {home.heroBadge}
        </p>
        <h1 style="font-size:clamp(2rem,5vw,3.25rem);font-weight:900;line-height:1.1;margin-bottom:1.25rem;letter-spacing:-0.02em;">
          {home.heroTitle1}<br/>
          <span style="color:#FF6B00;">{home.heroTitle2}</span><br/>
          {home.heroTitle3}
        </h1>
        <p style="font-size:1.125rem;line-height:1.7;opacity:0.9;max-width:520px;margin-bottom:2rem;">
          {home.heroSubtitle}
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="/idopontfoglalas" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {home.heroCtaPrimary}
          </a>
          <a href="/szolgaltatasok" class="btn-outline-white">
            {home.heroCtaSecondary}
          </a>
        </div>
      </div>

      <!-- Hero visual: háttér nélküli roller kép (glow háttérrel) + lebegő stat-kártyák -->
      <div class="hero-visual">
        <div class="hero-visual-card">
          <div class="hero-glow" aria-hidden="true"></div>
          <img src={home.heroImage || '/images/uploads/hero-roller.png'} alt="Elektromos roller" class="hero-photo"
            onerror="this.style.display='none';var s=this.parentElement.querySelector('.hero-svg');if(s)s.style.display='block';" />
          <svg class="hero-svg" style="display:none;" viewBox="0 0 200 200" width="200" height="200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="50" cy="150" r="35" stroke="white" stroke-width="6"/>
            <circle cx="50" cy="150" r="10" fill="white"/>
            <circle cx="160" cy="150" r="35" stroke="white" stroke-width="6"/>
            <circle cx="160" cy="150" r="10" fill="white"/>
            <path d="M50 115 L80 60 L130 60 L160 115" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M80 60 L90 20 L120 20" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="115" y="14" width="30" height="12" rx="6" fill="white"/>
            <path d="M105 60 L160 60" stroke="white" stroke-width="8" stroke-linecap="round"/>
          </svg>

          {home.stats?.[0] && (
            <div class="hero-badge hero-badge-tl">
              <span class="hero-badge-value" data-count>{home.stats[0].value}</span>
              <span class="hero-badge-label">{home.stats[0].label}</span>
            </div>
          )}
          {home.stats?.[1] && (
            <div class="hero-badge hero-badge-br">
              <span class="hero-badge-value" data-count>{home.stats[1].value}</span>
              <span class="hero-badge-label">{home.stats[1].label}</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ BRAND STRIP ═══════════════════════ -->
  <section style="background:#F8FAFC;border-bottom:1px solid #E2E8F0;padding:2rem 0;">
    <div class="container">
      <p style="text-align:center;font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#94A3B8;margin-bottom:1.5rem;">
        {home.brandStripTitle}
      </p>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;max-width:680px;margin:0 auto;">
        {[
          { name: 'Ninebot', sub: 'G30, G2 Max, F-széria', icon: '🛴' },
          { name: 'Kukirin', sub: 'G2, G3, G4 sorozat', icon: '⚡' },
          { name: 'Xiaomi-kompatibilis', sub: 'Replika / klón modellek', icon: '🔧' },
        ].map(brand => (
          <div style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:1.25rem 1rem;background:white;border-radius:1rem;border:1.5px solid #E2E8F0;transition:border-color 200ms;gap:0.5rem;"
            onmouseover="this.style.borderColor='#1848A0'"
            onmouseout="this.style.borderColor='#E2E8F0'">
            <span style="font-size:1.75rem;" aria-hidden="true">{brand.icon}</span>
            <strong style="font-size:1rem;font-weight:700;color:#1E293B;">{brand.name}</strong>
            <span style="font-size:0.8rem;color:#64748B;">{brand.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ TRUST STRIP ═══════════════════════ -->
  <section class="trust-strip">
    <div class="container" style="position:relative;z-index:1;">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;text-align:center;">
        {home.stats.map(stat => (
          <div>
            <p class="stat-value" data-count>{stat.value}</p>
            <p class="stat-label">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ SZOLGÁLTATÁSOK ═══════════════════════ -->
  <section class="section">
    <div class="container">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <p style="display:inline-block;color:#FF6B00;font-size:0.8rem;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.5rem;">Segíthetünk?</p>
        <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:900;color:#1E293B;margin-bottom:0.75rem;">Szolgáltatásaink</h2>
        <p style="color:#64748B;font-size:1rem;max-width:560px;margin:0 auto;">
          A defektcserétől a teljes tuningig – valódi diagnózissal, átlátható árakkal. Válaszd ki, miben segíthetek.
        </p>
      </div>

      <div style="display:grid;gap:1.25rem;grid-template-columns:1fr;" class="sm:grid-2 lg:grid-4">
        {[
          {
            title: 'Roller szerviz',
            icon: '<path d="M14.7 6.3a4 4 0 0 1-5.4 5.4L4 17v3h3l5.3-5.3a4 4 0 0 1 5.4-5.4l-2.3 2.3-2-2 2.3-2.3z"/>',
            desc: 'Elromlott, defektet kaptál vagy zörög a rollered? Diagnózissal kezdek, és csak azt cserélem, ami valóban kell.',
            points: ['Gumi- és defektcsere', 'Fék, féktárcsa, fékkar', 'Vezérlő és kijelző'],
            href: '/szolgaltatasok',
          },
          {
            title: 'Karbantartás & beállítás',
            icon: '<circle cx="12" cy="12" r="9"/><path d="M12 3v4M12 17v4M3 12h4M17 12h4"/>',
            desc: 'Rendszeres átvizsgálás, hogy a rollered sokáig, biztonságosan bírja a mindennapokat.',
            points: ['Teljes átvizsgálás', 'Precíz fékállítás', 'Csapágy és kenés'],
            href: '/szolgaltatasok',
          },
          {
            title: 'Tuning & fejlesztés',
            icon: '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2"/>',
            desc: 'Több hatótáv, nagyobb teljesítmény, egyedi megjelenés – személyre szabott megoldásokkal.',
            points: ['Akkumulátorépítés', 'Teljesítménynövelés', 'Egyedi világítás'],
            href: '/tuning',
          },
          {
            title: 'Szigetelés & védelem',
            icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
            desc: 'Leszigeteljük a rollert por és fröccsenő víz ellen – ajánlott a hosszabb élettartamhoz.',
            points: ['Porvédelem', 'Vízállóbb működés', 'Hosszabb élettartam'],
            href: '/szolgaltatasok',
          },
        ].map(svc => (
          <a href={svc.href} class="service-card">
            <div class="service-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
            </div>
            <strong style="font-size:1.15rem;font-weight:800;color:#1E293B;display:block;margin-bottom:0.5rem;">{svc.title}</strong>
            <p style="font-size:0.9rem;color:#64748B;line-height:1.6;margin-bottom:1rem;">{svc.desc}</p>
            <ul class="service-points">
              {svc.points.map(pt => (
                <li>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#FF6B00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  <span>{pt}</span>
                </li>
              ))}
            </ul>
            <span class="service-card-cta">Részletek
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ ROLLER TÍPUSOK ═══════════════════════ -->
  <section class="section">
    <div class="container">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:900;color:#1E293B;margin-bottom:0.75rem;">
          {home.modelsTitle}
        </h2>
        <p style="color:#64748B;font-size:1rem;max-width:520px;margin:0 auto;">
          {home.modelsSubtitle}
        </p>
      </div>

      <div style="display:grid;gap:1rem;grid-template-columns:1fr;" class="sm:grid-2 lg:grid-3">
        {scooters.map(s => {
          const cheapest = Math.min(...s.data.services.map(v => v.price));
          return (
            <a href={`/szolgaltatasok?roller=${s.id}`} class="model-card">
              <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;margin-bottom:0.75rem;">
                <div style="display:flex;align-items:center;gap:0.5rem;">
                  <img src={getBrandLogo(s.data.brand)} data-fallback={getBrandLogoFallback(s.data.brand)} alt={`${s.data.brand} logó`} width="48" height="48" style="width:48px;height:48px;border-radius:0.6rem;flex-shrink:0;object-fit:contain;" loading="lazy" onerror="if(this.src!==this.dataset.fallback){this.src=this.dataset.fallback;}" />
                  <span class="badge badge-brand">{s.data.brand}</span>
                </div>
                <span style="font-size:0.75rem;color:#94A3B8;font-weight:600;">{s.data.services.length} szolgáltatás</span>
              </div>
              <strong style="font-size:1.125rem;font-weight:800;color:#1E293B;display:block;margin-bottom:0.5rem;">{s.data.model}</strong>
              <span style="font-size:0.85rem;color:#64748B;">Szolgáltatások már {fmtHuf(cheapest)} Ft-tól</span>
              <span class="model-card-cta">
                Megnézem
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          );
        })}
      </div>

      <div style="text-align:center;margin-top:2rem;">
        <a href="/szolgaltatasok" class="btn-secondary">{home.modelsButton}</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ CTA SÁV ═══════════════════════ -->
  <section class="section" style="background:linear-gradient(135deg,#1848A0 0%,#1E5BBF 100%);color:white;">
    <div class="container" style="max-width:780px;margin:0 auto;text-align:center;">
      <p style="display:inline-block;background:rgba(255,107,0,0.25);color:#FFA060;font-size:0.8rem;font-weight:700;padding:0.35rem 0.875rem;border-radius:9999px;letter-spacing:0.06em;text-transform:uppercase;border:1px solid rgba(255,107,0,0.4);margin-bottom:1.25rem;">
        {home.ctaBadge}
      </p>
      <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:900;margin-bottom:1rem;letter-spacing:-0.01em;">
        {home.ctaTitle}
      </h2>
      <p style="font-size:1rem;line-height:1.7;opacity:0.9;margin-bottom:2rem;">
        {home.ctaText}
      </p>
      <a href="/idopontfoglalas" class="btn-primary" style="font-size:1.05rem;padding:0.875rem 2rem;">
        {home.ctaButton}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════ ABOUT ═══════════════════════ -->
  <section class="section">
    <div class="container" style="max-width:780px;margin:0 auto;">
      <div style="display:grid;gap:2rem;align-items:center;" class="md:grid-about">
        <div>
          {home.aboutImage ? (
            <img src={home.aboutImage} alt="Fix My Scoot – rólam" style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:3px solid #1848A0;margin-bottom:1.5rem;" />
          ) : (
            <div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);display:flex;align-items:center;justify-content:center;border:3px solid #1848A0;margin-bottom:1.5rem;">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="1.5" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
          )}
          <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:900;color:#1E293B;margin-bottom:1rem;">
            {home.aboutHeading}
          </h2>
          {home.aboutParagraphs.map(par => (
            <p style="color:#64748B;line-height:1.75;margin-bottom:1rem;">{par}</p>
          ))}
          <div style="margin-top:1.5rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/kapcsolat" class="btn-secondary">Elérhetőségek</a>
            <a href={SITE.socialViber} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3C6.9 3 3 6.6 3 11c0 2 .8 3.9 2.2 5.3L4.5 21l4.9-1.3c.8.2 1.7.3 2.6.3 5.1 0 9-3.6 9-8s-3.9-8-9-8z" fill="currentColor"/><circle cx="9" cy="11" r="1" fill="#1848A0"/><circle cx="12" cy="11" r="1" fill="#1848A0"/><circle cx="15" cy="11" r="1" fill="#1848A0"/></svg>
              Írj Viberen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ CONTACT SUMMARY ═══════════════════════ -->
  <section class="section" style="background:#F8FAFC;">
    <div class="container">
      <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:900;color:#1E293B;text-align:center;margin-bottom:2rem;">
        {home.contactTitle}
      </h2>
      <div style="display:grid;gap:1.5rem;" class="md:grid-contact">
        <!-- Info -->
        <div style="background:white;border-radius:1rem;border:1px solid #E2E8F0;padding:1.75rem;">
          <dl style="display:flex;flex-direction:column;gap:1rem;">
            {[
              { icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>', label: 'Cím', value: SITE.address.full },
              { icon: '<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.13 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>', label: 'Telefon', value: SITE.phoneDisplay, href: `tel:${SITE.phone}` },
              { icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>', label: 'Nyitvatartás', value: 'H–P: 09:00–18:00  |  Szo: 09:00–14:00' },
            ].map(item => (
              <div style="display:flex;gap:0.875rem;align-items:flex-start;">
                <div style="width:36px;height:36px;border-radius:0.5rem;background:#EFF6FF;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                </div>
                <div>
                  <dt style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.05em;">{item.label}</dt>
                  <dd style="font-size:0.95rem;font-weight:600;color:#1E293B;margin-top:0.125rem;">
                    {item.href ? <a href={item.href} style="color:#1848A0;text-decoration:none;">{item.value}</a> : item.value}
                  </dd>
                </div>
              </div>
            ))}
          </dl>
          <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #E2E8F0;display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/idopontfoglalas" class="btn-primary" style="flex:1;justify-content:center;min-width:140px;">Időpontot kérek</a>
            <a href="/kapcsolat" class="btn-secondary" style="flex:1;justify-content:center;min-width:140px;">Kapcsolat</a>
          </div>
        </div>

        <!-- Térkép -->
        <div style="border-radius:1rem;overflow:hidden;min-height:280px;border:1px solid #E2E8F0;">
          <iframe
            title="Fix My Scoot – térkép"
            src={SITE.mapEmbedUrl}
            width="100%" height="100%" style="border:0;min-height:280px;display:block;"
            loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) {
      .md\:grid-hero    { grid-template-columns: 1.2fr 0.8fr !important; }
      .md\:grid-ba      { grid-template-columns: repeat(3,1fr) !important; }
      .md\:grid-about   { grid-template-columns: 1fr !important; }
      .md\:grid-contact { grid-template-columns: 1fr 1.2fr !important; }
    }
    @media (min-width: 640px) {
      .sm\:grid-2 { grid-template-columns: repeat(2,1fr) !important; }
    }
    @media (min-width: 1024px) {
      .lg\:grid-3 { grid-template-columns: repeat(3,1fr) !important; }
      .lg\:grid-4 { grid-template-columns: repeat(4,1fr) !important; }
    }
    /* Hero vizuál: csak asztali nézetben */
    .hero-visual { display: none; }
    @media (min-width: 768px) {
      .hero-visual { display: flex; justify-content: center; align-items: center; }
    }
    .hero-visual-card {
      position: relative;
      width: 100%;
      max-width: 440px;
      aspect-ratio: 1 / 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    /* Izzó (glow) háttér a roller mögött */
    .hero-glow {
      position: absolute;
      inset: 5%;
      z-index: 0;
      background: radial-gradient(circle at 50% 52%, rgba(255,107,0,0.55) 0%, rgba(255,107,0,0.18) 42%, rgba(24,72,160,0) 70%);
      filter: blur(30px);
      animation: heroPulse 4.5s ease-in-out infinite;
    }
    @keyframes heroPulse {
      0%, 100% { opacity: 0.7; transform: scale(1); }
      50%      { opacity: 1;   transform: scale(1.08); }
    }
    .hero-photo {
      position: relative; z-index: 1;
      width: 100%; height: 100%;
      object-fit: contain;
      filter: drop-shadow(0 22px 40px rgba(0,0,0,0.45));
    }
    .hero-svg { position: relative; z-index: 1; opacity: 0.9; }
    .hero-badge {
      position: absolute;
      z-index: 2;
      background: white;
      border-radius: 0.875rem;
      padding: 0.7rem 1rem;
      box-shadow: 0 12px 30px rgba(0,0,0,0.28);
      display: flex;
      flex-direction: column;
      line-height: 1.1;
      min-width: 122px;
    }
    .hero-badge-tl { top: -0.6rem; left: -1.1rem; border-top: 3px solid #FF6B00; }
    .hero-badge-br { bottom: -0.6rem; right: -1.1rem; border-top: 3px solid #1848A0; }
    .hero-badge-value { font-size: 1.5rem; font-weight: 900; color: #1848A0; font-variant-numeric: tabular-nums; }
    .hero-badge-tl .hero-badge-value { color: #FF6B00; }
    .hero-badge-label { font-size: 0.72rem; font-weight: 600; color: #64748B; margin-top: 0.15rem; }

    /* Trust strip: színátmenetes glow háttér + izzó, felszámláló statisztikák */
    .trust-strip {
      position: relative;
      overflow: hidden;
      background: #0F172A;
      color: white;
      padding: 3.5rem 0;
    }
    .trust-strip::before {
      content: '';
      position: absolute; inset: 0; z-index: 0;
      background:
        radial-gradient(circle at 18% 50%, rgba(255,107,0,0.18), transparent 40%),
        radial-gradient(circle at 82% 50%, rgba(24,72,160,0.30), transparent 45%);
    }
    .stat-value {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 900;
      color: #FF6B00;
      line-height: 1;
      text-shadow: 0 0 26px rgba(255,107,0,0.45);
      font-variant-numeric: tabular-nums;
    }
    .stat-label { font-size: 0.9rem; color: #94A3B8; margin-top: 0.5rem; }

    @media (prefers-reduced-motion: reduce) {
      .hero-glow { animation: none; }
    }

    /* Szolgáltatás-kártyák */
    .service-card {
      display: flex;
      flex-direction: column;
      background: white;
      border: 1.5px solid #E2E8F0;
      border-radius: 1rem;
      padding: 1.5rem 1.375rem;
      text-decoration: none;
      transition: border-color 180ms, box-shadow 180ms, transform 180ms;
    }
    .service-card:hover {
      border-color: #1848A0;
      box-shadow: 0 12px 32px rgba(24,72,160,0.12);
      transform: translateY(-3px);
    }
    .service-icon {
      width: 52px; height: 52px;
      border-radius: 0.875rem;
      background: #0F172A;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1rem;
    }
    .service-points {
      list-style: none; margin: 0 0 1.25rem; padding: 0;
      display: flex; flex-direction: column; gap: 0.5rem;
    }
    .service-points li {
      display: flex; align-items: flex-start; gap: 0.5rem;
      font-size: 0.875rem; color: #475569;
    }
    .service-points li svg { flex-shrink: 0; margin-top: 2px; }
    .service-card-cta {
      display: inline-flex; align-items: center; gap: 0.35rem;
      margin-top: auto;
      color: #FF6B00; font-weight: 700; font-size: 0.875rem;
    }
    .model-card {
      display: flex;
      flex-direction: column;
      background: white;
      border: 1.5px solid #E2E8F0;
      border-radius: 1rem;
      padding: 1.25rem;
      text-decoration: none;
      transition: border-color 180ms, box-shadow 180ms, transform 180ms;
    }
    .model-card:hover {
      border-color: #1848A0;
      box-shadow: 0 10px 30px rgba(24,72,160,0.12);
      transform: translateY(-3px);
    }
    .model-card-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      margin-top: 0.875rem;
      color: #FF6B00;
      font-weight: 700;
      font-size: 0.875rem;
    }
  </style>

  <!-- Animált felszámláló a statisztikákhoz (láthatóvá váláskor indul) -->
  <script>
    (() => {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      function animateCount(el) {
        const raw = el.dataset.countText || el.textContent.trim();
        el.dataset.countText = raw;
        const m = raw.match(/(\d[\d\s.,]*)/);
        if (!m) return;
        const target = parseInt(m[1].replace(/[\s.,]/g, ''), 10);
        // Évszámot (>= 1000) nem animálunk, hogy ne tűnjön hibának
        if (isNaN(target) || target >= 1000 || prefersReduced) { el.textContent = raw; return; }
        const prefix = raw.slice(0, m.index);
        const suffix = raw.slice(m.index + m[1].length);
        const dur = 1400;
        const start = performance.now();
        el.textContent = prefix + '0' + suffix;
        function tick(now) {
          const p = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + Math.round(target * eased) + suffix;
          if (p < 1) requestAnimationFrame(tick);
          else el.textContent = raw;
        }
        requestAnimationFrame(tick);
      }
      const els = document.querySelectorAll('[data-count]');
      if (!els.length) return;
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { animateCount(e.target); io.unobserve(e.target); }
        });
      }, { threshold: 0.4 });
      els.forEach(el => io.observe(el));
    })();
  </script>
</Layout>
