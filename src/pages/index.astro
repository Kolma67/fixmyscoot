---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { getCollection } from 'astro:content';
import { getBrandLogo, getBrandLogoFallback } from '../config/brands';
import home from '../data/home.json';

const scooters = (await getCollection('scooters'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const fmtHuf = (n: number) => n.toLocaleString('hu-HU');

// LocalBusiness JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "description": SITE.description,
  "url": SITE.url,
  "telephone": SITE.phone,
  "email": SITE.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": SITE.address.street,
    "addressLocality": SITE.address.city,
    "postalCode": SITE.address.zip,
    "addressCountry": SITE.address.country,
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": SITE.geo.latitude,
    "longitude": SITE.geo.longitude,
  },
  "priceRange": SITE.priceRange,
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "14:00" },
  ],
  "knowsAbout": ["Ninebot elektromos roller javítás", "Kukirin roller szerviz", "Xiaomi-kompatibilis elektromos roller", "E-roller karbantartás"],
};

// BreadcrumbList
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Főoldal", "item": SITE.url }],
};
---

<Layout
  title={SITE.name}
  description={SITE.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />

  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section style="background:linear-gradient(135deg,#0F2F6E 0%,#1848A0 50%,#1E5BBF 100%);color:white;padding:5rem 0 4rem;">
    <div class="container" style="display:grid;gap:2.5rem;align-items:center;" class="md:grid-hero">
      <div>
        <p style="display:inline-block;background:rgba(255,107,0,0.2);color:#FFA060;font-size:0.8rem;font-weight:700;padding:0.35rem 0.875rem;border-radius:9999px;letter-spacing:0.06em;text-transform:uppercase;border:1px solid rgba(255,107,0,0.35);margin-bottom:1.25rem;">
          {home.heroBadge}
        </p>
        <h1 style="font-size:clamp(2rem,5vw,3.25rem);font-weight:900;line-height:1.1;margin-bottom:1.25rem;letter-spacing:-0.02em;">
          {home.heroTitle1}<br/>
          <span style="color:#FF6B00;">{home.heroTitle2}</span><br/>
          {home.heroTitle3}
        </h1>
        <p style="font-size:1.125rem;line-height:1.7;opacity:0.9;max-width:520px;margin-bottom:2rem;">
          {home.heroSubtitle}
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:0.875rem;">
          <a href="/idopontfoglalas" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Időpontot kérek
          </a>
          <a href="/szolgaltatasok" class="btn-outline-white">
            Összes szolgáltatás
          </a>
        </div>
      </div>

      <!-- Hero visual: feltöltött kép vagy stilizált roller rajz -->
      {home.heroImage ? (
        <div style="display:flex;justify-content:center;align-items:center;" class="hidden md:flex">
          <img src={home.heroImage} alt="Elektromos roller szerviz" style="width:100%;max-width:420px;border-radius:1.25rem;box-shadow:0 20px 50px rgba(0,0,0,0.25);object-fit:cover;" />
        </div>
      ) : (
      <div style="display:flex;justify-content:center;align-items:center;opacity:0.15;" class="hidden md:flex" aria-hidden="true">
        <svg viewBox="0 0 200 200" width="220" height="220" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="150" r="35" stroke="white" stroke-width="6"/>
          <circle cx="50" cy="150" r="10" fill="white"/>
          <circle cx="160" cy="150" r="35" stroke="white" stroke-width="6"/>
          <circle cx="160" cy="150" r="10" fill="white"/>
          <path d="M50 115 L80 60 L130 60 L160 115" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M80 60 L90 20 L120 20" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="115" y="14" width="30" height="12" rx="6" fill="white"/>
          <path d="M105 60 L160 60" stroke="white" stroke-width="8" stroke-linecap="round"/>
        </svg>
      </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════ BRAND STRIP ═══════════════════════ -->
  <section style="background:#F8FAFC;border-bottom:1px solid #E2E8F0;padding:2rem 0;">
    <div class="container">
      <p style="text-align:center;font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#94A3B8;margin-bottom:1.5rem;">
        Márkák, amelyekre specializálódtam
      </p>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;max-width:680px;margin:0 auto;">
        {[
          { name: 'Ninebot', sub: 'G30, G2 Max, F-széria', icon: '🛴' },
          { name: 'Kukirin', sub: 'G2, G3, G4 sorozat', icon: '⚡' },
          { name: 'Xiaomi-kompatibilis', sub: 'Replika / klón modellek', icon: '🔧' },
        ].map(brand => (
          <div style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:1.25rem 1rem;background:white;border-radius:1rem;border:1.5px solid #E2E8F0;transition:border-color 200ms;gap:0.5rem;"
            onmouseover="this.style.borderColor='#1848A0'"
            onmouseout="this.style.borderColor='#E2E8F0'">
            <span style="font-size:1.75rem;" aria-hidden="true">{brand.icon}</span>
            <strong style="font-size:1rem;font-weight:700;color:#1E293B;">{brand.name}</strong>
            <span style="font-size:0.8rem;color:#64748B;">{brand.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ TRUST STRIP ═══════════════════════ -->
  <section style="background:#0F172A;color:white;padding:3rem 0;">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;text-align:center;">
        {home.stats.map(stat => (
          <div>
            <p style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:#FF6B00;line-height:1;">{stat.value}</p>
            <p style="font-size:0.9rem;color:#94A3B8;margin-top:0.375rem;">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ ROLLER TÍPUSOK ═══════════════════════ -->
  <section class="section">
    <div class="container">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:900;color:#1E293B;margin-bottom:0.75rem;">
          Mely rollerekhez értek?
        </h2>
        <p style="color:#64748B;font-size:1rem;max-width:520px;margin:0 auto;">
          Válaszd ki a rollered típusát, és azonnal látod a hozzá tartozó szolgáltatásokat és pontos árakat.
        </p>
      </div>

      <div style="display:grid;gap:1rem;grid-template-columns:1fr;" class="sm:grid-2 lg:grid-3">
        {scooters.map(s => {
          const cheapest = Math.min(...s.data.services.map(v => v.price));
          return (
            <a href={`/szolgaltatasok?roller=${s.id}`} class="model-card">
              <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;margin-bottom:0.75rem;">
                <div style="display:flex;align-items:center;gap:0.5rem;">
                  <img src={getBrandLogo(s.data.brand)} data-fallback={getBrandLogoFallback(s.data.brand)} alt={`${s.data.brand} logó`} width="48" height="48" style="width:48px;height:48px;border-radius:0.6rem;flex-shrink:0;object-fit:contain;" loading="lazy" onerror="if(this.src!==this.dataset.fallback){this.src=this.dataset.fallback;}" />
                  <span class="badge badge-brand">{s.data.brand}</span>
                </div>
                <span style="font-size:0.75rem;color:#94A3B8;font-weight:600;">{s.data.services.length} szolgáltatás</span>
              </div>
              <strong style="font-size:1.125rem;font-weight:800;color:#1E293B;display:block;margin-bottom:0.5rem;">{s.data.model}</strong>
              <span style="font-size:0.85rem;color:#64748B;">Szolgáltatások már {fmtHuf(cheapest)} Ft-tól</span>
              <span class="model-card-cta">
                Megnézem
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          );
        })}
      </div>

      <div style="text-align:center;margin-top:2rem;">
        <a href="/szolgaltatasok" class="btn-secondary">Összes szolgáltatás és ár</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ CTA SÁV ═══════════════════════ -->
  <section class="section" style="background:linear-gradient(135deg,#1848A0 0%,#1E5BBF 100%);color:white;">
    <div class="container" style="max-width:780px;margin:0 auto;text-align:center;">
      <p style="display:inline-block;background:rgba(255,107,0,0.25);color:#FFA060;font-size:0.8rem;font-weight:700;padding:0.35rem 0.875rem;border-radius:9999px;letter-spacing:0.06em;text-transform:uppercase;border:1px solid rgba(255,107,0,0.4);margin-bottom:1.25rem;">
        Javítás &amp; karbantartás
      </p>
      <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:900;margin-bottom:1rem;letter-spacing:-0.01em;">
        Nem indul, fékez vagy zörög a rollered?
      </h2>
      <p style="font-size:1rem;line-height:1.7;opacity:0.9;margin-bottom:2rem;">
        Defektcserétől a vezérlőelektronikáig – gumicsere, fék, kijelző, csapágy, szigetelés.
        Diagnózissal kezdek, és csak azt cserélem, ami valóban kell.
      </p>
      <a href="/idopontfoglalas" class="btn-primary" style="font-size:1.05rem;padding:0.875rem 2rem;">
        Időpontot kérek
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════ ABOUT ═══════════════════════ -->
  <section class="section">
    <div class="container" style="max-width:780px;margin:0 auto;">
      <div style="display:grid;gap:2rem;align-items:center;" class="md:grid-about">
        <div>
          {home.aboutImage ? (
            <img src={home.aboutImage} alt="Fix My Scoot – rólam" style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:3px solid #1848A0;margin-bottom:1.5rem;" />
          ) : (
            <div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);display:flex;align-items:center;justify-content:center;border:3px solid #1848A0;margin-bottom:1.5rem;">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="1.5" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
          )}
          <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:900;color:#1E293B;margin-bottom:1rem;">
            {home.aboutHeading}
          </h2>
          {home.aboutParagraphs.map(par => (
            <p style="color:#64748B;line-height:1.75;margin-bottom:1rem;">{par}</p>
          ))}
          <div style="margin-top:1.5rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/kapcsolat" class="btn-secondary">Elérhetőségek</a>
            <a href={SITE.socialWhatsApp} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Írj WhatsApp-on
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ CONTACT SUMMARY ═══════════════════════ -->
  <section class="section" style="background:#F8FAFC;">
    <div class="container">
      <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:900;color:#1E293B;text-align:center;margin-bottom:2rem;">
        Hol találsz meg?
      </h2>
      <div style="display:grid;gap:1.5rem;" class="md:grid-contact">
        <!-- Info -->
        <div style="background:white;border-radius:1rem;border:1px solid #E2E8F0;padding:1.75rem;">
          <dl style="display:flex;flex-direction:column;gap:1rem;">
            {[
              { icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>', label: 'Cím', value: SITE.address.full },
              { icon: '<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.13 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>', label: 'Telefon', value: SITE.phoneDisplay, href: `tel:${SITE.phone}` },
              { icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>', label: 'Nyitvatartás', value: 'H–P: 09:00–18:00  |  Szo: 09:00–14:00' },
            ].map(item => (
              <div style="display:flex;gap:0.875rem;align-items:flex-start;">
                <div style="width:36px;height:36px;border-radius:0.5rem;background:#EFF6FF;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                </div>
                <div>
                  <dt style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.05em;">{item.label}</dt>
                  <dd style="font-size:0.95rem;font-weight:600;color:#1E293B;margin-top:0.125rem;">
                    {item.href ? <a href={item.href} style="color:#1848A0;text-decoration:none;">{item.value}</a> : item.value}
                  </dd>
                </div>
              </div>
            ))}
          </dl>
          <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #E2E8F0;display:flex;gap:0.75rem;flex-wrap:wrap;">
            <a href="/idopontfoglalas" class="btn-primary" style="flex:1;justify-content:center;min-width:140px;">Időpontot kérek</a>
            <a href="/kapcsolat" class="btn-secondary" style="flex:1;justify-content:center;min-width:140px;">Kapcsolat</a>
          </div>
        </div>

        <!-- Map placeholder -->
        <div style="background:#E2E8F0;border-radius:1rem;overflow:hidden;min-height:280px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.75rem;color:#94A3B8;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#CBD5E1" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <p style="font-size:0.85rem;font-weight:500;">Térkép betöltése…</p>
          <a href={`https://maps.google.com/?q=${SITE.address.googleMapsQuery}`}
            target="_blank" rel="noopener noreferrer"
            style="font-size:0.8rem;color:#1848A0;font-weight:600;text-decoration:none;">
            Megnyitás Google Maps-ben ↗
          </a>
          <!-- TODO: Replace with real Google Maps embed after enabling GDPR cookie consent -->
          <!-- <iframe src="https://maps.google.com/maps?q=..." width="100%" height="100%" style="border:0;" loading="lazy" allowfullscreen></iframe> -->
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) {
      .md\:grid-hero    { grid-template-columns: 1.2fr 0.8fr !important; }
      .md\:grid-ba      { grid-template-columns: repeat(3,1fr) !important; }
      .md\:grid-about   { grid-template-columns: 1fr !important; }
      .md\:grid-contact { grid-template-columns: 1fr 1.2fr !important; }
    }
    @media (min-width: 640px) {
      .sm\:grid-2 { grid-template-columns: repeat(2,1fr) !important; }
    }
    @media (min-width: 1024px) {
      .lg\:grid-3 { grid-template-columns: repeat(3,1fr) !important; }
    }
    @media (min-width: 768px) {
      .hidden.md\:flex { display: flex !important; }
    }
    .model-card {
      display: flex;
      flex-direction: column;
      background: white;
      border: 1.5px solid #E2E8F0;
      border-radius: 1rem;
      padding: 1.25rem;
      text-decoration: none;
      transition: border-color 180ms, box-shadow 180ms, transform 180ms;
    }
    .model-card:hover {
      border-color: #1848A0;
      box-shadow: 0 10px 30px rgba(24,72,160,0.12);
      transform: translateY(-3px);
    }
    .model-card-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      margin-top: 0.875rem;
      color: #FF6B00;
      font-weight: 700;
      font-size: 0.875rem;
    }
  </style>
</Layout>
