---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { getCollection } from 'astro:content';

const items = (await getCollection('tuning'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const fmt = (n: number) => n.toLocaleString('hu-HU');

const description = 'Elektromos roller tuning és fejlesztés Budapesten: akkumulátorépítés, VESC-vezérlő beépítés, szoftveres tuning, teljesítménynövelés, egyedi világítás és dizájn.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Főoldal', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Tuning', item: `${SITE.url}/tuning` },
  ],
};
---

<Layout title="Tuning és fejlesztés" description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />

  <!-- Hero -->
  <section class="hero-gradient" style="color:white;padding:3.5rem 0 3rem;">
    <div class="container" style="max-width:720px;margin:0 auto;text-align:center;">
      <p style="display:inline-block;background:rgba(255,107,0,0.2);color:#FFA060;font-size:0.78rem;font-weight:700;padding:0.3rem 0.875rem;border-radius:9999px;letter-spacing:0.07em;text-transform:uppercase;border:1px solid rgba(255,107,0,0.35);margin-bottom:1.25rem;">
        Tuning &amp; fejlesztés
      </p>
      <h1 style="font-size:clamp(1.75rem,5vw,2.75rem);font-weight:900;line-height:1.15;margin-bottom:1rem;letter-spacing:-0.02em;">
        Hozd ki a maximumot a rolleredből
      </h1>
      <p style="font-size:1.05rem;line-height:1.75;opacity:0.9;">
        Több hatótáv, nagyobb teljesítmény, egyedi megjelenés. A tuning munkák egyediek –
        mondd el, mit szeretnél, és személyre szabott ajánlatot adok.
      </p>
    </div>
  </section>

  <!-- Kártyák -->
  <section class="section">
    <div class="container">
      <div style="display:grid;gap:1.5rem;grid-template-columns:1fr;" class="sm:grid-2">
        {items.map(item => (
          <article class="card" style="display:flex;flex-direction:column;overflow:hidden;">
            <!-- kép / ikon -->
            <div style="position:relative;aspect-ratio:16/9;background:#EFF2F7;display:flex;align-items:center;justify-content:center;">
              {item.data.image ? (
                <img src={item.data.image} alt={item.data.title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
              ) : null}
              <div style={`width:100%;height:100%;${item.data.image ? 'display:none;' : 'display:flex;'}align-items:center;justify-content:center;position:absolute;inset:0;color:#FF6B00;`}>
                <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </div>
            </div>

            <div style="padding:1.25rem 1.375rem;display:flex;flex-direction:column;flex:1;">
              <h2 style="font-size:1.15rem;font-weight:800;color:#1E293B;margin-bottom:0.5rem;line-height:1.25;">{item.data.title}</h2>
              <p style="font-size:0.9rem;color:#64748B;line-height:1.6;margin-bottom:1rem;">{item.data.description}</p>

              {item.data.options.length > 0 && (
                <ul style="list-style:none;margin:0 0 1.25rem;padding:0;display:flex;flex-direction:column;gap:0.5rem;">
                  {item.data.options.map(opt => (
                    <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.875rem;color:#475569;">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF6B00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                      <span>{opt}</span>
                    </li>
                  ))}
                </ul>
              )}

              <div style="margin-top:auto;display:flex;align-items:center;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;">
                <div>
                  <span style="font-size:0.72rem;color:#94A3B8;display:block;">Ár</span>
                  <span style="font-size:1.05rem;font-weight:900;color:#1848A0;">
                    {item.data.price != null ? `${fmt(item.data.price)} Ft${item.data.note ?? ''}` : (item.data.priceText ?? 'egyedi ajánlat')}
                  </span>
                </div>
                <a href={`/kapcsolat?tema=${encodeURIComponent(item.data.title)}#ajanlatkeres`} class="btn-primary" style="font-size:0.9rem;padding:0.55rem 1.1rem;">Ajánlatot kérek</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Alsó CTA -->
      <div style="margin-top:2.5rem;text-align:center;padding:2rem;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);border-radius:1.25rem;border:1.5px solid #BFDBFE;">
        <h2 style="font-size:1.25rem;font-weight:800;color:#1E293B;margin-bottom:0.625rem;">Egyedi elképzelésed van?</h2>
        <p style="color:#64748B;margin-bottom:1.25rem;max-width:520px;margin-left:auto;margin-right:auto;">
          A tuning mindig személyre szabott. Írd meg, mit szeretnél elérni – hatótáv, sebesség vagy külső –, és együtt kitaláljuk a legjobb megoldást.
        </p>
        <div style="display:flex;gap:0.875rem;justify-content:center;flex-wrap:wrap;">
          <a href="/kapcsolat#ajanlatkeres" class="btn-primary">Ajánlatot kérek</a>
          <a href={`tel:${SITE.phone}`} class="btn-secondary">Hívás</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 640px) { .sm\:grid-2 { grid-template-columns: repeat(2,1fr) !important; } }
  </style>
</Layout>
