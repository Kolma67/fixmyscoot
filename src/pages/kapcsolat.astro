---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { weeklySchedule } from '../config/openingHours';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Főoldal", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Kapcsolat", "item": `${SITE.url}/kapcsolat` },
  ],
};

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "telephone": SITE.phone,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": SITE.address.street,
    "addressLocality": SITE.address.city,
    "postalCode": SITE.address.zip,
    "addressCountry": SITE.address.country,
  },
  "url": SITE.url,
};
---

<Layout title="Kapcsolat" description={`Elérhetőségek, cím és nyitvatartás. Fix My Scoot elektromos roller szerviz – ${SITE.address.full}. Tel: ${SITE.phoneDisplay}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} slot="head" />

  <section style="background:linear-gradient(135deg,#0F2F6E 0%,#1848A0 100%);color:white;padding:3rem 0 2.5rem;">
    <div class="container" style="max-width:600px;margin:0 auto;text-align:center;">
      <h1 style="font-size:clamp(1.75rem,5vw,2.5rem);font-weight:900;margin-bottom:0.75rem;">Kapcsolat</h1>
      <p style="font-size:1rem;opacity:0.9;">Elérhetőségek, cím és nyitvatartás.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:900px;margin:0 auto;">
      <div style="display:grid;gap:2rem;" class="md:grid-contact-page">

        <!-- Contact cards -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">

          <!-- Phone -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;display:flex;align-items:center;gap:1rem;">
            <div style="width:48px;height:48px;border-radius:0.75rem;background:#EFF6FF;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.13 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div style="flex:1;">
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.125rem;">Telefon</p>
              <a href={`tel:${SITE.phone}`} style="font-size:1.2rem;font-weight:800;color:#1848A0;text-decoration:none;">{SITE.phoneDisplay}</a>
              <p style="font-size:0.8rem;color:#94A3B8;margin-top:0.25rem;">Kattintásra felhív</p>
            </div>
            <a href={`tel:${SITE.phone}`} class="btn-primary" style="padding:0.5rem 1rem;font-size:0.85rem;flex-shrink:0;">Hívás</a>
          </div>

          <!-- WhatsApp -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;display:flex;align-items:center;gap:1rem;">
            <div style="width:48px;height:48px;border-radius:0.75rem;background:#DCFCE7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="#22C55E" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div style="flex:1;">
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.125rem;">WhatsApp</p>
              <p style="font-size:1rem;font-weight:700;color:#1E293B;">{SITE.phoneDisplay}</p>
              <p style="font-size:0.8rem;color:#94A3B8;margin-top:0.25rem;">Üzenj bármikor</p>
            </div>
            <a href={SITE.socialWhatsApp} target="_blank" rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;background:#22C55E;color:white;font-size:0.85rem;font-weight:600;border-radius:0.625rem;text-decoration:none;flex-shrink:0;transition:background 150ms;"
              onmouseover="this.style.background='#16A34A'" onmouseout="this.style.background='#22C55E'">
              WhatsApp
            </a>
          </div>

          <!-- Address -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;display:flex;align-items:center;gap:1rem;">
            <div style="width:48px;height:48px;border-radius:0.75rem;background:#FFF3E0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF6B00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div style="flex:1;">
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.125rem;">Cím</p>
              <p style="font-size:1rem;font-weight:700;color:#1E293B;">{SITE.address.full}</p>
              <p style="font-size:0.8rem;color:#94A3B8;margin-top:0.25rem;">Budapest, III. kerület</p>
            </div>
            <a href={`https://maps.google.com/?q=${SITE.address.googleMapsQuery}`}
              target="_blank" rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;background:#FFF3E0;color:#FF6B00;font-size:0.85rem;font-weight:600;border-radius:0.625rem;text-decoration:none;flex-shrink:0;border:1px solid rgba(255,107,0,0.2);transition:background 150ms;"
              onmouseover="this.style.background='#FFE0B2'" onmouseout="this.style.background='#FFF3E0'">
              Térkép ↗
            </a>
          </div>

          <!-- Hours -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
              <div style="width:48px;height:48px;border-radius:0.75rem;background:#EFF6FF;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;">Nyitvatartás</p>
            </div>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
              {weeklySchedule.map(day => (
                <li style="display:flex;justify-content:space-between;font-size:0.9rem;padding:0.375rem 0;border-bottom:1px solid #F8FAFC;">
                  <span style={`font-weight:${day.open ? '600' : '400'};color:${day.open ? '#1E293B' : '#94A3B8'};`}>{day.name}</span>
                  <span style={`color:${day.open ? '#1848A0' : '#94A3B8'};font-weight:${day.open ? '700' : '400'};font-style:${day.open ? 'normal' : 'italic'};`}>
                    {day.open ? day.hours : 'Zárva'}
                  </span>
                </li>
              ))}
            </ul>
            <p style="margin-top:0.875rem;font-size:0.8rem;color:#64748B;line-height:1.6;padding:0.625rem;background:#F8FAFC;border-radius:0.5rem;">
              A nyitvatartás rugalmas – ha nem fér be a fenti keretbe, egyeztessünk előre.
            </p>
          </div>
        </div>

        <!-- Map placeholder -->
        <div style="background:#E2E8F0;border-radius:1rem;overflow:hidden;min-height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;color:#94A3B8;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#CBD5E1" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <p style="font-size:0.9rem;font-weight:600;">1039 Budapest, Frigyes utca 10.</p>
          <a href={`https://maps.google.com/?q=${SITE.address.googleMapsQuery}`}
            target="_blank" rel="noopener noreferrer"
            style="padding:0.625rem 1.25rem;background:#1848A0;color:white;border-radius:0.625rem;text-decoration:none;font-size:0.875rem;font-weight:600;transition:background 150ms;"
            onmouseover="this.style.background='#133680'" onmouseout="this.style.background='#1848A0'">
            Megnyitás Google Maps-ben ↗
          </a>
          <!-- TODO: Add Google Maps embed iframe here after setting up GDPR consent -->
        </div>
      </div>

      <!-- CTA -->
      <div style="margin-top:2.5rem;text-align:center;padding:2rem;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);border-radius:1.25rem;border:1.5px solid #BFDBFE;">
        <h2 style="font-size:1.25rem;font-weight:800;color:#1E293B;margin-bottom:0.625rem;">Készen állsz?</h2>
        <p style="color:#64748B;margin-bottom:1.25rem;">Foglalj időpontot online, vagy hívj közvetlenül.</p>
        <div style="display:flex;gap:0.875rem;justify-content:center;flex-wrap:wrap;">
          <a href="/idopontfoglalas" class="btn-primary">Időpontfoglalás</a>
          <a href={`tel:${SITE.phone}`} class="btn-secondary">Hívás</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 768px) {
      .md\:grid-contact-page { grid-template-columns: 1fr 1.1fr !important; }
    }
  </style>
</Layout>
