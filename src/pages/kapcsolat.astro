---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { weeklySchedule } from '../config/openingHours';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Főoldal", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Kapcsolat", "item": `${SITE.url}/kapcsolat` },
  ],
};

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "telephone": SITE.phone,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": SITE.address.street,
    "addressLocality": SITE.address.city,
    "postalCode": SITE.address.zip,
    "addressCountry": SITE.address.country,
  },
  "url": SITE.url,
};
---

<Layout title="Kapcsolat" description={`Elérhetőségek, cím és nyitvatartás. Fix My Scoot elektromos roller szerviz – ${SITE.address.full}. Tel: ${SITE.phoneDisplay}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} slot="head" />

  <section class="hero-gradient" style="color:white;padding:3rem 0 2.5rem;">
    <div class="container" style="max-width:600px;margin:0 auto;text-align:center;">
      <h1 style="font-size:clamp(1.75rem,5vw,2.5rem);font-weight:900;margin-bottom:0.75rem;">Kapcsolat</h1>
      <p style="font-size:1rem;opacity:0.9;">Elérhetőségek, cím és nyitvatartás.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:900px;margin:0 auto;">
      <div style="display:grid;gap:2rem;" class="md:grid-contact-page">

        <!-- Contact cards -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">

          <!-- Phone -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;display:flex;align-items:center;gap:1rem;">
            <div style="width:48px;height:48px;border-radius:0.75rem;background:#EFF6FF;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.13 1.18 2 2 0 012.11 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div style="flex:1;">
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.125rem;">Telefon</p>
              <a href={`tel:${SITE.phone}`} style="font-size:1.2rem;font-weight:800;color:#1848A0;text-decoration:none;">{SITE.phoneDisplay}</a>
              <p style="font-size:0.8rem;color:#94A3B8;margin-top:0.25rem;">Kattintásra felhív</p>
            </div>
            <a href={`tel:${SITE.phone}`} class="btn-primary" style="padding:0.5rem 1rem;font-size:0.85rem;flex-shrink:0;">Hívás</a>
          </div>

          <!-- Viber -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;display:flex;align-items:center;gap:1rem;">
            <div style="width:48px;height:48px;border-radius:0.75rem;background:#EDE9FE;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3C6.9 3 3 6.6 3 11c0 2 .8 3.9 2.2 5.3L4.5 21l4.9-1.3c.8.2 1.7.3 2.6.3 5.1 0 9-3.6 9-8s-3.9-8-9-8z" fill="#7360F2"/><circle cx="9" cy="11" r="1" fill="#fff"/><circle cx="12" cy="11" r="1" fill="#fff"/><circle cx="15" cy="11" r="1" fill="#fff"/></svg>
            </div>
            <div style="flex:1;">
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.125rem;">Viber</p>
              <p style="font-size:1rem;font-weight:700;color:#1E293B;">{SITE.phoneDisplay}</p>
              <p style="font-size:0.8rem;color:#94A3B8;margin-top:0.25rem;">Üzenj bármikor</p>
            </div>
            <a href={SITE.socialViber} target="_blank" rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;background:#7360F2;color:white;font-size:0.85rem;font-weight:600;border-radius:0.625rem;text-decoration:none;flex-shrink:0;transition:background 150ms;"
              onmouseover="this.style.background='#5b48d6'" onmouseout="this.style.background='#7360F2'">
              Viber
            </a>
          </div>

          <!-- Address -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;display:flex;align-items:center;gap:1rem;">
            <div style="width:48px;height:48px;border-radius:0.75rem;background:#FFF3E0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF6B00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div style="flex:1;">
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.125rem;">Cím</p>
              <p style="font-size:1rem;font-weight:700;color:#1E293B;">{SITE.address.full}</p>
              <p style="font-size:0.8rem;color:#94A3B8;margin-top:0.25rem;">Budapest, III. kerület</p>
            </div>
            <a href={`https://maps.google.com/?q=${SITE.address.googleMapsQuery}`}
              target="_blank" rel="noopener noreferrer"
              style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.5rem 1rem;background:#FFF3E0;color:#FF6B00;font-size:0.85rem;font-weight:600;border-radius:0.625rem;text-decoration:none;flex-shrink:0;border:1px solid rgba(255,107,0,0.2);transition:background 150ms;"
              onmouseover="this.style.background='#FFE0B2'" onmouseout="this.style.background='#FFF3E0'">
              Térkép ↗
            </a>
          </div>

          <!-- Hours -->
          <div style="background:white;border:1.5px solid #E2E8F0;border-radius:1rem;padding:1.5rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
              <div style="width:48px;height:48px;border-radius:0.75rem;background:#EFF6FF;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1848A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <p style="font-size:0.75rem;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;">Nyitvatartás</p>
            </div>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
              {weeklySchedule.map(day => (
                <li style="display:flex;justify-content:space-between;font-size:0.9rem;padding:0.375rem 0;border-bottom:1px solid #F8FAFC;">
                  <span style={`font-weight:${day.open ? '600' : '400'};color:${day.open ? '#1E293B' : '#94A3B8'};`}>{day.name}</span>
                  <span style={`color:${day.open ? '#1848A0' : '#94A3B8'};font-weight:${day.open ? '700' : '400'};font-style:${day.open ? 'normal' : 'italic'};`}>
                    {day.open ? day.hours : 'Zárva'}
                  </span>
                </li>
              ))}
            </ul>
            <p style="margin-top:0.875rem;font-size:0.8rem;color:#64748B;line-height:1.6;padding:0.625rem;background:#F8FAFC;border-radius:0.5rem;">
              A nyitvatartás rugalmas – ha nem fér be a fenti keretbe, egyeztessünk előre.
            </p>
          </div>
        </div>

        <!-- Térkép -->
        <div style="border-radius:1rem;overflow:hidden;min-height:400px;border:1.5px solid #E2E8F0;">
          <iframe
            title="Fix My Scoot – térkép"
            src={SITE.mapEmbedUrl}
            width="100%" height="100%" style="border:0;min-height:400px;display:block;"
            loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
        </div>
      </div>

      <!-- CTA -->
      <div style="margin-top:2.5rem;text-align:center;padding:2rem;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);border-radius:1.25rem;border:1.5px solid #BFDBFE;">
        <h2 style="font-size:1.25rem;font-weight:800;color:#1E293B;margin-bottom:0.625rem;">Készen állsz?</h2>
        <p style="color:#64748B;margin-bottom:1.25rem;">Foglalj időpontot online, kérj ajánlatot, vagy hívj közvetlenül.</p>
        <div style="display:flex;gap:0.875rem;justify-content:center;flex-wrap:wrap;">
          <a href="/idopontfoglalas" class="btn-primary">Időpontfoglalás</a>
          <a href="#ajanlatkeres" class="btn-secondary">Ajánlatkérés</a>
          <a href={`tel:${SITE.phone}`} class="btn-secondary">Hívás</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ajánlatkérés / üzenet (Netlify Forms) -->
  <section class="section" id="ajanlatkeres" style="background:#F8FAFC;border-top:1px solid #E2E8F0;">
    <div class="container" style="max-width:700px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2rem;">
        <h2 style="font-size:clamp(1.5rem,4vw,2rem);font-weight:900;color:#1E293B;margin-bottom:0.75rem;">Ajánlatkérés / üzenet</h2>
        <p style="font-size:1rem;color:#64748B;line-height:1.7;max-width:520px;margin:0 auto;">
          Egyedi munka, tuning vagy csak egy kérdés? Írd meg, miben segíthetek – hamarosan válaszolok telefonon vagy e-mailben.
        </p>
      </div>

      <form id="quote-form" name="quote" method="POST" data-netlify="true" netlify-honeypot="bot-field" novalidate
        style="background:white;border:1.5px solid #E2E8F0;border-radius:1.25rem;padding:2rem;display:flex;flex-direction:column;gap:1.375rem;">

        <input type="hidden" name="form-name" value="quote" />
        <p style="display:none;"><label>Ne töltsd ki, ha ember vagy: <input name="bot-field" /></label></p>

        <!-- Teljes név -->
        <div>
          <label for="q-name" style="display:block;font-size:0.875rem;font-weight:600;color:#374151;margin-bottom:0.375rem;">
            Teljes neve <span style="color:#EF4444;" aria-label="kötelező">*</span>
          </label>
          <input type="text" id="q-name" name="name" required autocomplete="name"
            placeholder="Kovács János"
            style="width:100%;padding:0.7rem 0.875rem;border:1.5px solid #E2E8F0;border-radius:0.625rem;font-size:0.95rem;outline:none;transition:border-color 150ms;box-sizing:border-box;"
            onfocus="this.style.borderColor='#1848A0'" onblur="this.style.borderColor='#E2E8F0'" />
          <p class="q-field-error" id="q-name-error" style="display:none;font-size:0.78rem;color:#EF4444;margin-top:0.25rem;"></p>
        </div>

        <!-- Telefonszám -->
        <div>
          <label for="q-phone" style="display:block;font-size:0.875rem;font-weight:600;color:#374151;margin-bottom:0.375rem;">
            Telefonszám <span style="color:#EF4444;" aria-label="kötelező">*</span>
          </label>
          <input type="tel" id="q-phone" name="phone" required autocomplete="tel"
            placeholder="+36 30 123 4567"
            style="width:100%;padding:0.7rem 0.875rem;border:1.5px solid #E2E8F0;border-radius:0.625rem;font-size:0.95rem;outline:none;transition:border-color 150ms;box-sizing:border-box;"
            onfocus="this.style.borderColor='#1848A0'" onblur="this.style.borderColor='#E2E8F0'" />
          <p class="q-field-error" id="q-phone-error" style="display:none;font-size:0.78rem;color:#EF4444;margin-top:0.25rem;"></p>
        </div>

        <!-- E-mail (opcionális) -->
        <div>
          <label for="q-email" style="display:block;font-size:0.875rem;font-weight:600;color:#374151;margin-bottom:0.375rem;">
            E-mail cím <span style="font-weight:400;color:#94A3B8;">(opcionális, válaszhoz)</span>
          </label>
          <input type="email" id="q-email" name="email" autocomplete="email"
            placeholder="kovacs.janos@email.com"
            style="width:100%;padding:0.7rem 0.875rem;border:1.5px solid #E2E8F0;border-radius:0.625rem;font-size:0.95rem;outline:none;transition:border-color 150ms;box-sizing:border-box;"
            onfocus="this.style.borderColor='#1848A0'" onblur="this.style.borderColor='#E2E8F0'" />
        </div>

        <!-- Téma / miről van szó -->
        <div>
          <label for="q-subject" style="display:block;font-size:0.875rem;font-weight:600;color:#374151;margin-bottom:0.375rem;">
            Miről van szó? <span style="font-weight:400;color:#94A3B8;">(pl. tuning, alkatrész, roller típusa)</span>
          </label>
          <input type="text" id="q-subject" name="subject"
            placeholder="Pl. tuning – hatótáv növelés"
            style="width:100%;padding:0.7rem 0.875rem;border:1.5px solid #E2E8F0;border-radius:0.625rem;font-size:0.95rem;outline:none;transition:border-color 150ms;box-sizing:border-box;"
            onfocus="this.style.borderColor='#1848A0'" onblur="this.style.borderColor='#E2E8F0'" />
        </div>

        <!-- Üzenet -->
        <div>
          <label for="q-message" style="display:block;font-size:0.875rem;font-weight:600;color:#374151;margin-bottom:0.375rem;">
            Üzenet <span style="color:#EF4444;" aria-label="kötelező">*</span>
          </label>
          <textarea id="q-message" name="message" rows="5" required
            placeholder="Írd le, mit szeretnél elérni, milyen rollered van, milyen munkára gondoltál..."
            style="width:100%;padding:0.7rem 0.875rem;border:1.5px solid #E2E8F0;border-radius:0.625rem;font-size:0.95rem;outline:none;resize:vertical;transition:border-color 150ms;box-sizing:border-box;font-family:inherit;"
            onfocus="this.style.borderColor='#1848A0'" onblur="this.style.borderColor='#E2E8F0'"></textarea>
          <p class="q-field-error" id="q-message-error" style="display:none;font-size:0.78rem;color:#EF4444;margin-top:0.25rem;"></p>
        </div>

        <!-- GDPR consent -->
        <div style="display:flex;align-items:flex-start;gap:0.625rem;">
          <input type="checkbox" id="q-gdpr" name="gdpr_consent" value="yes" required
            style="width:18px;height:18px;margin-top:2px;flex-shrink:0;accent-color:#1848A0;cursor:pointer;" />
          <label for="q-gdpr" style="font-size:0.85rem;color:#64748B;line-height:1.5;cursor:pointer;">
            Elfogadom az <a href="/adatkezelesi-tajekoztato" style="color:#1848A0;font-weight:600;" target="_blank">adatkezelési tájékoztatót</a>.
            Az adataimat kizárólag a kapcsolatfelvételhez használják fel.
            <span style="color:#EF4444;" aria-label="kötelező">*</span>
          </label>
        </div>
        <p class="q-field-error" id="q-gdpr-error" style="display:none;font-size:0.78rem;color:#EF4444;margin-top:-1rem;"></p>

        <!-- Submit -->
        <button type="submit" id="q-submit-btn" class="btn-primary" style="width:100%;justify-content:center;font-size:1.05rem;padding:0.875rem;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Ajánlatkérés küldése
        </button>
      </form>

      <!-- Success state -->
      <div id="quote-success" hidden
        style="background:white;border:1.5px solid #22C55E;border-radius:1.25rem;padding:3rem 2rem;text-align:center;">
        <div style="width:64px;height:64px;background:#DCFCE7;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2 style="font-size:1.5rem;font-weight:900;color:#1E293B;margin-bottom:0.75rem;">Köszönöm az üzenetet!</h2>
        <p style="color:#64748B;line-height:1.7;max-width:400px;margin:0 auto;">
          Megkaptam a kérésedet és hamarosan válaszolok telefonon vagy e-mailben.
        </p>
      </div>

      <!-- Error state -->
      <div id="quote-error" hidden
        style="background:#FEF2F2;border:1.5px solid #EF4444;border-radius:0.875rem;padding:1.25rem;margin-top:1rem;text-align:center;">
        <p style="color:#DC2626;font-weight:600;margin-bottom:0.5rem;">Sajnos hiba történt az elküldés során.</p>
        <p style="color:#64748B;font-size:0.9rem;">Kérlek hívj közvetlenül: <a href={`tel:${SITE.phone}`} style="color:#1848A0;font-weight:700;">{SITE.phoneDisplay}</a></p>
      </div>
    </div>
  </section>

  <script>
    const qForm = document.getElementById('quote-form');
    const qSubmit = document.getElementById('q-submit-btn');
    const qSuccess = document.getElementById('quote-success');
    const qError = document.getElementById('quote-error');

    // Téma előtöltése a tuning oldalról: /kapcsolat?tema=...#ajanlatkeres
    const qParams = new URLSearchParams(window.location.search);
    const preSubject = qParams.get('tema');
    const subjectInput = document.getElementById('q-subject');
    if (preSubject && subjectInput) {
      subjectInput.value = preSubject;
    }

    function qShowError(id, msg) {
      const el = document.getElementById(id);
      if (el) { el.textContent = msg; el.style.display = 'block'; }
    }
    function qClearErrors() {
      document.querySelectorAll('.q-field-error').forEach(el => { el.style.display = 'none'; });
    }
    function qValidate() {
      qClearErrors();
      let valid = true;
      const name = document.getElementById('q-name').value.trim();
      const phone = document.getElementById('q-phone').value.trim();
      const message = document.getElementById('q-message').value.trim();
      const gdpr = document.getElementById('q-gdpr').checked;
      if (!name) { qShowError('q-name-error', 'Kérlek add meg a nevedet.'); valid = false; }
      if (!phone || phone.length < 8) { qShowError('q-phone-error', 'Érvényes telefonszámot adj meg.'); valid = false; }
      if (!message) { qShowError('q-message-error', 'Kérlek írd le röviden, miben segíthetek.'); valid = false; }
      if (!gdpr) { qShowError('q-gdpr-error', 'Az adatkezelési tájékoztató elfogadása kötelező.'); valid = false; }
      if (!valid) {
        const first = document.querySelector('.q-field-error[style*="block"]');
        first?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return valid;
    }

    qForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!qValidate()) return;
      if (qError) qError.hidden = true;
      qSubmit.disabled = true;
      qSubmit.textContent = 'Küldés…';
      const body = new URLSearchParams(new FormData(qForm)).toString();
      try {
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
        });
        if (res.ok) {
          qForm.hidden = true;
          if (qSuccess) qSuccess.hidden = false;
          qSuccess?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error('submit failed');
        }
      } catch {
        if (qError) qError.hidden = false;
        qSubmit.disabled = false;
        qSubmit.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Ajánlatkérés küldése';
      }
    });
  </script>

  <style>
    @media (min-width: 768px) {
      .md\:grid-contact-page { grid-template-columns: 1fr 1.1fr !important; }
    }
  </style>
</Layout>
